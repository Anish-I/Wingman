# =============================================================================
# TextFlow Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# -- Telnyx (SMS) -------------------------------------------------------------
TELNYX_API_KEY=your_telnyx_api_v2_key
TELNYX_PHONE_NUMBER=+1234567890
TELNYX_MESSAGING_PROFILE_ID=40019cb7-3f22-4f10-b535-c9fb1068c15f
# Optional: set to your Telnyx webhook public key for signature verification in production
TELNYX_PUBLIC_KEY=

# -- Together AI (LLM) --------------------------------------------------------
TOGETHER_API_KEY=your_together_api_key
TOGETHER_MODEL=meta-llama/Llama-4-Maverick-17B-128E-Instruct
TOGETHER_MODEL_COMPLEX=meta-llama/Llama-4-Maverick-17B-128E-Instruct
MAX_TOKENS=2048

# -- Zapier (Integrations) ----------------------------------------------------
ZAPIER_API_KEY=your_zapier_api_key
ZAPIER_EMBED_CLIENT_ID=your_zapier_embed_client_id
ZAPIER_EMBED_CLIENT_SECRET=your_zapier_embed_client_secret
ZAPIER_PARTNER_TOKEN=your_zapier_partner_token

# -- Database (PostgreSQL) ----------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/textflow

# -- Cache (Redis) ------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -- Server -------------------------------------------------------------------
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001
ONBOARDING_URL=https://textflow.ai/connect
CORS_ORIGIN=http://localhost:3000

# -- Web (Next.js) ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- Auth / Security ----------------------------------------------------------
JWT_SECRET=your_jwt_secret_here
WEBHOOK_SECRET=your_webhook_secret_here
