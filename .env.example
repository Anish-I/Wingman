# =============================================================================
# TextFlow Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# -- Twilio (SMS) -------------------------------------------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid

# -- Anthropic (AI) -----------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key

# -- Zapier (Integrations) ----------------------------------------------------
ZAPIER_API_KEY=your_zapier_api_key
ZAPIER_EMBED_CLIENT_ID=your_zapier_embed_client_id
ZAPIER_EMBED_CLIENT_SECRET=your_zapier_embed_client_secret
ZAPIER_PARTNER_TOKEN=your_zapier_partner_token

# -- Database (PostgreSQL) ----------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/textflow

# -- Cache (Redis) ------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -- Server -------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# -- Web (Next.js) ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- Auth / Security ----------------------------------------------------------
JWT_SECRET=your_jwt_secret_here
WEBHOOK_SECRET=your_webhook_secret_here
