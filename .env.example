# =============================================================================
# Wingman — Environment Variables Template
# =============================================================================
#
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below.
#   3. For development, you can also use .env.development (auto-loaded by
#      some tooling). For production, use .env.production.
#
# NOTES:
#   - MESSAGING_PROVIDER: "stub" (dev, logs to console) or "twilio" (real SMS)
#   - LLM_PROVIDER: "gemini" or "together"
#   - NODE_ENV: "development" or "production"
#   - Never commit .env, .env.development, or .env.production to git.
#     Only .env.example is tracked.
#
# =============================================================================

# -- SMS Provider (Twilio) ---------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
MESSAGING_PROVIDER=stub

# -- LLM --------------------------------------------------------------------
TOGETHER_API_KEY=
TOGETHER_MODEL=gemini-2.5-flash
TOGETHER_MODEL_COMPLEX=gemini-2.5-flash
MAX_TOKENS=2048
GEMINI_API_KEY=
GROQ_API_KEY=
LLM_PROVIDER=gemini

# -- Composio (App Integrations) ---------------------------------------------
COMPOSIO_API_KEY=

# -- Database (PostgreSQL) -----------------------------------------------------
# These must match docker-compose.yml; override for production
POSTGRES_USER=change_me
POSTGRES_PASSWORD=change_me
POSTGRES_DB=wingman
DATABASE_URL=
SUPABASE_URL=

# -- Cache (Redis) -----------------------------------------------------------
REDIS_URL=redis://localhost:6379
# Password must match docker-compose.yml --requirepass value
REDIS_PASSWORD=change_me

# -- Server ------------------------------------------------------------------
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001
ONBOARDING_URL=http://localhost:3000/connect
CORS_ORIGIN=http://localhost:3000

# -- Expo app ----------------------------------------------------------------
EXPO_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- Google OAuth ------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# -- Auth / Security ---------------------------------------------------------
JWT_SECRET=
WEBHOOK_SECRET=
