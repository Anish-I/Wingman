# ============================================
# Wingman Server — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to version control.
# ============================================

# ---------- Core ----------
NODE_ENV=development
PORT=3001
BASE_URL=http://localhost:3001
# Production frontend URL
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# ---------- Database (PostgreSQL) ----------
DATABASE_URL=postgresql://wingman:wingman@localhost:5432/wingman

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- Authentication ----------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate_64_char_random_string

# ---------- Google OAuth ----------
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ---------- LLM Providers (configure at least one) ----------
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
TOGETHER_API_KEY=your_together_api_key_here
TOGETHER_MODEL=gemini-2.5-flash
TOGETHER_MODEL_COMPLEX=gemini-2.5-flash
GROQ_API_KEY=your_groq_api_key_here
MAX_TOKENS=2048

# ---------- Messaging (configure one provider) ----------
MESSAGING_PROVIDER=stub

# Telnyx
TELNYX_API_KEY=your_telnyx_api_key_here
TELNYX_PHONE_NUMBER=+15551234567
TELNYX_MESSAGING_PROFILE_ID=your_telnyx_messaging_profile_id_here
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# Twilio (alternative to Telnyx)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# ---------- Composio ----------
COMPOSIO_API_KEY=your_composio_api_key_here

# ---------- n8n (optional) ----------
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=your_n8n_api_key_here

# ---------- Frontend URL ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
