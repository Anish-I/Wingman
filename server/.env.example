# ============================================
# Wingman Server — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to version control.
# ============================================

# ---------- Core ----------
NODE_ENV=development
PORT=3001
BASE_URL=http://localhost:3001
# Production frontend URL(s). Comma-separate multiple approved web origins.
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# ---------- HTTPS Enforcement ----------
# Set TRUST_PROXY when behind a reverse proxy / load balancer (e.g. 'loopback', '1', 'true')
# TRUST_PROXY=loopback
# Force HTTPS redirect + HSTS even outside production (auto-enabled when NODE_ENV=production)
# FORCE_HTTPS=true

# ---------- Database (PostgreSQL) ----------
DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@localhost:5432/wingman
# SSL is enforced automatically for all remote (non-localhost) connections.
# Set DATABASE_SSL=false only to explicitly disable SSL (e.g. local dev with remote DB).
# Set DATABASE_CA_CERT to a PEM string to pin a specific CA certificate.
# DATABASE_SSL=false

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379
# Must match docker-compose.yml --requirepass value
REDIS_PASSWORD=change_me

# ---------- Cookies ----------
# Secure flag on auth/OAuth cookies (default: true).
# Set to 'false' only for local dev over plain HTTP.
# COOKIE_SECURE=false

# ---------- Authentication ----------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate_64_char_random_string
#
# KEY ROTATION (optional): Set JWT_SECRETS to a JSON array to support rotation.
# First entry = current signing key; older entries verify existing tokens.
# When set, JWT_SECRET is ignored. To rotate:
#   1. Generate a new 64+ char secret
#   2. Prepend it as the first entry with a new kid
#   3. Keep the old key(s) until their tokens expire (24h + 2h grace)
#   4. Remove expired keys from the array
# JWT_SECRETS=[{"kid":"v2","secret":"<new 64+ char secret>"},{"kid":"v1","secret":"<old secret>"}]
#
# REQUIRED: Dedicated secret for OTP HMAC hashing (must differ from JWT_SECRET)
OTP_SECRET=generate_another_64_char_random_string
# REQUIRED: Dedicated secret for OAuth state token signing (must differ from JWT_SECRET)
OAUTH_STATE_SECRET=generate_yet_another_64_char_random_string

# ---------- Google OAuth ----------
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ---------- LLM Providers (configure at least one) ----------
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
TOGETHER_API_KEY=your_together_api_key_here
TOGETHER_MODEL=gemini-2.5-flash
TOGETHER_MODEL_COMPLEX=gemini-2.5-flash
GROQ_API_KEY=your_groq_api_key_here
MAX_TOKENS=2048

# ---------- Messaging (configure one provider) ----------
MESSAGING_PROVIDER=stub

# Telnyx
TELNYX_API_KEY=your_telnyx_api_key_here
TELNYX_PHONE_NUMBER=+15551234567
TELNYX_MESSAGING_PROFILE_ID=your_telnyx_messaging_profile_id_here
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# Twilio (alternative to Telnyx)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# ---------- Composio ----------
COMPOSIO_API_KEY=your_composio_api_key_here

# ---------- n8n (optional) ----------
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=your_n8n_api_key_here

# ---------- Frontend URL ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
