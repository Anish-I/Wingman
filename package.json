{
  "name": "textflow",
  "version": "1.0.0",
  "description": "TextFlow — Your entire digital life, one text away. SMS-native AI agent powered by Claude, Twilio, and Zapier.",
  "private": true,
  "workspaces": ["server", "web"],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:web": "npm run dev --workspace=web",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "install:all": "npm install --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
